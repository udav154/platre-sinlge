# Resend - отправка писем с формы контактов
# Получить API ключ: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email, на который приходят сообщения
CONTACT_EMAIL=email@example.com

# Отправитель (для production верифицируйте домен на https://resend.com/domains)
# Для тестов можно оставить onboarding@resend.dev
RESEND_FROM=Platre <onboarding@resend.dev>
